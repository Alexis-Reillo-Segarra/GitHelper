# Proveedor de IA a usar: "gemini", "openai", "anthropic", "kimi" o "minimax".
# Lo más cómodo es configurarlo con el asistente interactivo: ejecuta `git-helper`.
AI_PROVIDER=gemini

# (Opcional) Forzar un modelo concreto. Por defecto:
#   gemini    -> gemini-2.5-flash
#   openai    -> gpt-4o-mini
#   anthropic -> claude-haiku-4-5-20251001  (también: claude-sonnet-4-6, claude-opus-4-8)
#   kimi      -> kimi-k2-0711-preview
#   minimax   -> MiniMax-M1
# AI_MODEL=claude-sonnet-4-6

# (Opcional) Base URL para proveedores compatibles con OpenAI (kimi/minimax).
# Solo si quieres sobreescribir la por defecto o usar un proxy.
# AI_BASE_URL=

# (Opcional) Nº de ejecuciones del ensemble por análisis (mediana). Por defecto 3.
# Más ejecuciones = más consistencia pero más llamadas a la IA. Pon 1 para desactivar.
# AI_ENSEMBLE_RUNS=3

# Clave del proveedor elegido (rellena solo la que uses).
# Gemini   -> https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# OpenAI   -> https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Claude   -> https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Kimi     -> https://platform.moonshot.ai/console/api-keys
MOONSHOT_API_KEY=
# MiniMax  -> https://www.minimax.io/platform
MINIMAX_API_KEY=

# (Opcional) Token de GitHub para subir el rate limit / acceder a repos privados
# GITHUB_TOKEN=
