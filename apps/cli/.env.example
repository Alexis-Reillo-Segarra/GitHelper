# Proveedor de IA a usar: "gemini" u "openai"
AI_PROVIDER=gemini

# (Opcional) Forzar un modelo concreto. Por defecto:
#   gemini -> gemini-2.5-flash
#   openai -> gpt-4o-mini
# AI_MODEL=gemini-2.5-flash

# (Opcional) Nº de ejecuciones del ensemble por análisis (mediana). Por defecto 3.
# Más ejecuciones = más consistencia pero más llamadas a la IA. Pon 1 para desactivar.
# AI_ENSEMBLE_RUNS=3

# Clave de Google AI Studio (requerida si AI_PROVIDER=gemini)
# Consíguela en https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Clave de OpenAI (requerida si AI_PROVIDER=openai)
OPENAI_API_KEY=

# (Opcional) Token de GitHub para subir el rate limit / acceder a repos privados
# GITHUB_TOKEN=
